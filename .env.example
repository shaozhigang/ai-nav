# ====================================
# Database Configuration
# ====================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# ====================================
# Authentication (Better Auth)
# ====================================
# Secret key for Better Auth (must be at least 32 characters in production)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-characters-long-for-production"

# The URL where your app is hosted
BETTER_AUTH_URL="http://localhost:3000"

# ====================================
# Google OAuth (Optional)
# ====================================
# Get these from: https://console.cloud.google.com/
# Guide: https://authjs.dev/getting-started/providers/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Public Google OAuth settings
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED="true"
NEXT_PUBLIC_AUTH_GOOGLE_ONE_TAP_ENABLED="true"

# ====================================
# Email Service (Required for email features)
# ====================================
# Resend API for transactional emails
# Get your API key from: https://resend.com
RESEND_API_KEY="re_your_api_key"

# Email Configuration - Choose one of the following options:
#
# Set a complete from email address (recommended, highest priority)
RESEND_FROM_EMAIL="Your App <noreply@yourdomain.com>"

# Optional: Resend Audience ID for newsletter/marketing
RESEND_AUDIENCE_ID="your-resend-audience-id"

# ====================================
# Analytics & Monitoring (Optional)
# ====================================
# Posthog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# Analytics Feature Flags（可选）
NEXT_PUBLIC_ANALYTICS_ENABLE_IN_DEVELOPMENT=""

# ====================================
# Storage Configuration (Optional - for file uploads)
# ====================================
# R2/S3-compatible storage for file uploads
# Works with Cloudflare R2, AWS S3, MinIO, etc.
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""
STORAGE_BUCKET_NAME="uploads"
STORAGE_PUBLIC_URL=""

# ====================================
# Application Settings
# ====================================
# Public app URL (update in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"

# ====================================
# Feature Flags (Optional)
# ====================================
# Enable/disable features
NEXT_PUBLIC_MAINTENANCE_MODE="false"
